# Per-project launcher configuration (sourced by claude-dev.sh).
# Update via chore Issue when project identity or image registry changes.

#Github repo 
GH_OWNER=nightjarrr
GH_REPO=molim

# Claude dev container image
DEVENV_IMAGE=molim-devenv
 
# Envoy perimeter sidecar configuration
ENVOY_IMAGE=envoyproxy/envoy:v1.33.14
ENVOY_ADMIN_HOST_PORT=7001
ENVOY_ADMIN_CONTAINER_PORT=9901
ENVOY_ADMIN_ADDRESS=0.0.0.0
ENVOY_SOCKET_CONTAINER_PATH=/run/claude-dev-proxy/proxy.sock
