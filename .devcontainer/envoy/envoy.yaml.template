# ======================================================================
# Claude dev egress proxy
#
# Envoy HTTP/HTTPS forward proxy reachable through a Unix domain socket.
# Intended to be used from a networkless container through a local
# TCP-to-UDS bridge.
#
# Request path:
#
#   application
#     -> HTTP_PROXY / HTTPS_PROXY endpoint on loopback
#     -> TCP-to-UDS bridge
#     -> Envoy Unix domain socket listener
#     -> Envoy RBAC policy
#     -> Envoy dynamic forward proxy
#     -> upstream destination
#
# Template placeholders filled by launcher:
#
#   __ENVOY_SOCKET_PATH__      Unix socket path inside Envoy container
#   __ENVOY_ADMIN_ADDRESS__    Envoy admin bind address inside container
#   __ENVOY_ADMIN_PORT__       Envoy admin bind port inside container
# ======================================================================

node:
  id: claude-dev-egress-proxy
  cluster: claude-dev-local

# ----------------------------------------------------------------------
# Admin interface.
#
# The admin listener is intended to be published only to host loopback,
# for example:
#
#   127.0.0.1:7001 -> __ENVOY_ADMIN_ADDRESS__:__ENVOY_ADMIN_PORT__ (e.g., 0.0.0.0:9901)
#
# The admin interface exposes operational state and potentially sensitive
# configuration data. It must not be exposed to untrusted networks.
# ----------------------------------------------------------------------
admin:
  access_log_path: /tmp/envoy-admin-access.log
  address:
    socket_address:
      protocol: TCP
      address: __ENVOY_ADMIN_ADDRESS__
      port_value: __ENVOY_ADMIN_PORT__

static_resources:
  listeners:
    - name: claude_dev_proxy_uds_listener

      # ----------------------------------------------------------------
      # Downstream listener.
      #
      # Envoy accepts explicit proxy traffic on a Unix domain socket.
      # The socket path is inside the Envoy container. The parent
      # directory is bind-mounted from the host runtime directory.
      # ----------------------------------------------------------------
      address:
        pipe:
          path: __ENVOY_SOCKET_PATH__

          # [TODO] 438 decimal == 0666 octal. Suitable for initial
          # validation when the parent runtime directory is private and
          # per-run. Tighten to 432 / 0660 after UID/GID ownership between
          # Envoy and the client container is finalized.
          mode: 438

      filter_chains:
        - filters:
            - name: envoy.filters.network.http_connection_manager
              typed_config:
                "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager

                stat_prefix: claude_dev_forward_proxy
                codec_type: AUTO

                # ------------------------------------------------------
                # CONNECT support.
                #
                # Explicit HTTPS proxying uses HTTP CONNECT:
                #
                #   CONNECT example.com:443 HTTP/1.1
                #
                # Envoy does not enable CONNECT handling by default.
                # This listener-level upgrade declaration enables CONNECT
                # processing for routes that also opt in below.
                # ------------------------------------------------------
                upgrade_configs:
                  - upgrade_type: CONNECT

                # ------------------------------------------------------
                # Route configuration.
                #
                # The route table accepts both:
                #
                #   - CONNECT requests for HTTPS tunneling
                #   - ordinary HTTP proxy requests using absolute-form URIs
                #
                # Access control is handled by RBAC filters, not by these
                # broad routes. The routes intentionally forward all
                # policy-approved requests to the dynamic forward proxy
                # cluster.
                # ------------------------------------------------------
                route_config:
                  name: claude_dev_forward_proxy_routes

                  virtual_hosts:
                    - name: forward_proxy_virtual_host

                      # Routing accepts all authorities. Restriction is
                      # enforced by RBAC before dynamic forwarding.
                      domains:
                        - "*"

                      routes:
                        # ------------------------------------------------
                        # HTTPS over explicit proxy.
                        #
                        # HTTP/1.1 CONNECT requests generally do not carry
                        # a path, so connect_matcher is used instead of
                        # prefix/path matching.
                        #
                        # connect_config enables tunneling after Envoy
                        # accepts the CONNECT request. Envoy does not
                        # terminate TLS in this mode.
                        # ------------------------------------------------
                        - match:
                            connect_matcher: {}

                          route:
                            cluster: dynamic_forward_proxy_cluster
                            timeout: 0s

                            upgrade_configs:
                              - upgrade_type: CONNECT
                                connect_config: {}

                        # ------------------------------------------------
                        # Plain HTTP over explicit proxy.
                        #
                        # Example request shape:
                        #
                        #   GET http://example.com/path HTTP/1.1
                        #   Host: example.com
                        #
                        # The dynamic forward proxy filter and cluster
                        # derive the upstream host from request authority.
                        # ------------------------------------------------
                        - match:
                            prefix: "/"

                          route:
                            cluster: dynamic_forward_proxy_cluster
                            timeout: 0s

                # ------------------------------------------------------
                # Access log.
                #
                # Logs are written to stdout and are available through:
                #
                #   docker logs <envoy-container>
                #
                # For CONNECT requests, :AUTHORITY usually contains
                # host:port and :PATH is normally absent or empty.
                # ------------------------------------------------------
                access_log:
                  - name: envoy.access_loggers.stdout
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.access_loggers.stream.v3.StdoutAccessLog
                      log_format:
                        text_format_source:
                          inline_string: >-
                            [%START_TIME%] method=%REQ(:METHOD)% authority=%REQ(:AUTHORITY)%
                            path=%REQ(:PATH)% status=%RESPONSE_CODE% flags=%RESPONSE_FLAGS%
                            upstream=%UPSTREAM_HOST% duration_ms=%DURATION%

                # ------------------------------------------------------
                # HTTP filter chain.
                #
                # Filter order is security-relevant:
                #
                #   1. allow-list RBAC
                #   2. dynamic forward proxy resolver
                #   3. router
                #
                # RBAC runs before DNS resolution and upstream connection.
                # The dynamic forward proxy filter must run before the
                # router and must share its DNS cache name with the dynamic
                # forward proxy cluster.
                # ------------------------------------------------------
                http_filters:
                  # ----------------------------------------------------
                  # Allow-list.
                  #
                  # Action ALLOW implements default-deny semantics:
                  #
                  #   - request matches at least one policy -> allowed
                  #   - request matches no policies          -> denied
                  #
                  # [TODO] Replace allow_all_initial_validation with
                  # specific destination policies before enabling this
                  # proxy for untrusted workloads.
                  # ----------------------------------------------------
                  - name: envoy.filters.http.rbac
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.rbac.v3.RBAC
                      rules:
                        action: ALLOW
                        policies:

                          # ------------------------------------------------
                          # [TODO] Temporary allow-all wildcard validation rule.
                          #
                          # Allows all requests that reach the proxy. This
                          # makes the dynamic forward proxy unrestricted.
                          # Remove before using the proxy as a security
                          # boundary.
                          # ------------------------------------------------
                          allow_all:
                            permissions:
                              - any: true
                            principals:
                              - any: true

                          # ------------------------------------------------
                          # Future allow-list examples.
                          #
                          # Match on :authority. For CONNECT, :authority
                          # normally includes host:port. For plain HTTP,
                          # :authority normally contains the HTTP Host value.
                          #
                          # Uncomment and adjust after removing
                          # allow_all policy.
                          # ------------------------------------------------

                          # allow_anthropic_api:
                          #   permissions:
                          #     - or_rules:
                          #         rules:
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "api.anthropic.com"
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "api.anthropic.com:443"
                          #   principals:
                          #     - any: true

                          # allow_github_api:
                          #   permissions:
                          #     - or_rules:
                          #         rules:
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "api.github.com"
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "api.github.com:443"
                          #   principals:
                          #     - any: true

                          # allow_github_web:
                          #   permissions:
                          #     - or_rules:
                          #         rules:
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "github.com"
                          #           - header:
                          #               name: ":authority"
                          #               string_match:
                          #                 exact: "github.com:443"
                          #   principals:
                          #     - any: true

                          # allow_githubusercontent:
                          #   permissions:
                          #     - header:
                          #         name: ":authority"
                          #         string_match:
                          #           safe_regex:
                          #             google_re2: {}
                          #             regex: "^([A-Za-z0-9-]+\\.)*githubusercontent\\.com(:443)?$"
                          #   principals:
                          #     - any: true

                  # ----------------------------------------------------
                  # Dynamic forward proxy HTTP filter.
                  #
                  # Resolves and caches upstream destinations derived from
                  # the incoming explicit proxy request. The DNS cache name
                  # must match the dynamic forward proxy cluster config.
                  # ----------------------------------------------------
                  - name: envoy.filters.http.dynamic_forward_proxy
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.dynamic_forward_proxy.v3.FilterConfig

                      dns_cache_config:
                        name: claude_dev_forward_proxy_dns_cache
                        dns_lookup_family: V4_ONLY

                        dns_cache_circuit_breaker:
                          max_pending_requests: 1024

                  # ----------------------------------------------------
                  # Router.
                  #
                  # Sends policy-approved and resolved requests to the
                  # selected upstream through the configured route cluster.
                  # ----------------------------------------------------
                  - name: envoy.filters.http.router
                    typed_config:
                      "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router

  clusters:
    # ------------------------------------------------------------------
    # Dynamic forward proxy cluster.
    #
    # Upstream destinations are not declared as static endpoints. The
    # dynamic forward proxy filter derives the target host/port from each
    # request, resolves it, and uses this cluster to open the upstream
    # connection.
    #
    # The dns_cache_config name must match the HTTP filter above.
    # ------------------------------------------------------------------
    - name: dynamic_forward_proxy_cluster

      lb_policy: CLUSTER_PROVIDED
      connect_timeout: 10s

      circuit_breakers:
        thresholds:
          - priority: DEFAULT
            max_connections: 1024
            max_pending_requests: 1024
            max_requests: 1024
            max_retries: 3

      cluster_type:
        name: envoy.clusters.dynamic_forward_proxy
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.clusters.dynamic_forward_proxy.v3.ClusterConfig

          dns_cache_config:
            name: claude_dev_forward_proxy_dns_cache
            dns_lookup_family: V4_ONLY

            dns_cache_circuit_breaker:
              max_pending_requests: 1024
